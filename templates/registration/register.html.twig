{% extends 'base.html.twig' %}

{% block title %}YunoBudget - Inscription{% endblock %}

{% block body %}
<style>
    :root {
        --bg-main: #0B0B0C;
        --card-bg: #161618;
        --input-bg: #1F1F22;
        --border-color: #2D2D31;
        --text-primary: #FFFFFF;
        --text-secondary: #8E8E93;
        --error-color: #FF453A;
    }

    .register-wrapper, .register-wrapper * {
        box-sizing: border-box;
    }

    .register-wrapper {
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-main);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        padding: 20px;
        overflow: hidden;
    }

    .register-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        padding: 35px 35px;
        border-radius: 14px;
        width: 100%;
        max-width: 400px;
    }

    .register-header {
        text-align: center;
        margin-bottom: 24px;
    }

    .register-header h1 {
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
    }

    .register-header p {
        font-size: 13px;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.4;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }

    .form-group input {
        width: 100%;
        padding: 11px 14px;
        font-size: 14px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background-color: var(--input-bg);
        color: var(--text-primary);
        transition: border-color 0.2s ease;
    }

    .form-group input:focus {
        outline: none;
        border-color: #55555A;
    }

    .form-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

    .form-checkbox input[type="checkbox"] {
        accent-color: var(--text-primary);
        width: 15px;
        height: 15px;
        cursor: pointer;
    }

    .form-checkbox label {
        font-size: 13px;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background-color: var(--text-primary);
        color: var(--bg-main);
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .btn-submit:hover {
        opacity: 0.9;
    }

    .form-errors {
        background: rgba(255, 69, 58, 0.1);
        border: 1px solid rgba(255, 69, 58, 0.2);
        padding: 10px;
        border-radius: 8px;
        color: var(--error-color);
        font-size: 13px;
        margin-bottom: 16px;
        text-align: center;
    }

    .login-link {
        text-align: center;
        margin-top: 18px;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .login-link a {
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 500;
        margin-left: 4px;
    }

    .login-link a:hover {
        text-decoration: underline;
    }

    .register-footer {
        margin-top: 24px;
        font-size: 11px;
        color: #444448;
        text-align: center;
    }
</style>

<div class="register-wrapper">
    <div class="register-card">
        <div class="register-header">
            <h1>Créer un compte</h1>
            <p>Rejoignez Yuno et pilotez votre budget en toute sécurité.</p>
        </div>

        {% if not registrationForm.vars.valid %}
            <div class="form-errors">
                {{ form_errors(registrationForm) }}
                {{ form_errors(registrationForm.email) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
        {% endif %}

        {{ form_start(registrationForm) }}
            <div class="form-group">
                {{ form_label(registrationForm.email, "Adresse Email") }}
                {{ form_widget(registrationForm.email, {'attr': {'placeholder': 'nom@exemple.com'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword, "Mot de passe") }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'placeholder': '••••••••'}}) }}
            </div>

            {% if registrationForm.agreeTerms is defined %}
                <div class="form-checkbox">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation") }}
                </div>
            {% endif %}

            {{ form_widget(registrationForm._token) }}

            <button type="submit" class="btn-submit">S'inscrire</button>
        {{ form_end(registrationForm, {'render_rest': false}) }}

        <div class="login-link">
            Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

    <div class="register-footer">
        &copy; 2026 YunoBudget &bull; Obsidian Precision
    </div>
</div>
{% endblock %}