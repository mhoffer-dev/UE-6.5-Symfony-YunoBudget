{% extends 'base.html.twig' %}

{% block title %}Modifier la Transaction - YunoBudget{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <h1 class="text-3xl font-bold text-gray-900">✏️ Modifier la transaction</h1>
        <a href="{{ path('app_transaction_index') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700">
            &larr; Retour à la liste
        </a>
    </div>

    <div class="bg-white shadow sm:rounded-lg p-6 border border-gray-100">
        {{ include('transaction/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>

    <div class="mt-4 flex justify-end">
        {{ include('transaction/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}