{% extends 'base.html.twig' %}

{% block title %}Modifier la transaction — Yuno Budget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_transaction_index') }}" class="text-[var(--text-secondary)] hover:text-violet-500 transition-colors text-base font-mono font-bold">
            &larr; Retour
        </a>
    </div>

    <!-- Section du Montant -->
    <div class="text-center py-4">
        <span class="text-[10px] uppercase tracking-widest font-bold text-[var(--text-secondary)] block">Montant actuel</span>
        <div class="flex justify-center items-baseline text-[var(--text-primary)] mt-1">
            <span class="text-4xl font-extrabold tracking-tight">{{ transaction.montant|number_format(2, ',', ' ') }}</span>
            <span class="text-xl font-bold text-violet-500 ml-1">€</span>
        </div>
        <div class="w-12 h-0.5 bg-gradient-to-r from-violet-500 to-pink-500 mx-auto mt-2 rounded-full"></div>
    </div>

    <!-- Formulaire dans une carte en verre -->
    <div class="glass-panel p-6 rounded-2xl text-sm mt-2">
        {{ include('transaction/_form.html.twig', {
            'button_label': 'Enregistrer les modifications',
            'transaction': transaction
        }) }}
    </div>
    
</div>
{% endblock %}