{% extends 'base.html.twig' %}

{% block title %}Nouvelle Transaction - YunoBudget{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto mt-4">
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-indigo-100 text-indigo-600 text-3xl mb-3 shadow-inner">
            💸
        </div>
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Ajouter un mouvement</h1>
        <p class="mt-2 text-sm text-gray-500">Enregistrez un nouveau revenu ou une nouvelle dépense instantanément.</p>
    </div>

    <div class="bg-white shadow-xl rounded-2xl border border-gray-100 p-8">
        {{ include('transaction/_form.html.twig') }}
        
        <div class="mt-6 pt-4 border-t border-gray-100 text-center">
            <a href="{{ path('app_transaction_index') }}" class="text-sm font-medium text-gray-400 hover:text-indigo-600 transition-colors">
                &larr; Annuler et revenir à la liste
            </a>
        </div>
    </div>
</div>
{% endblock %}