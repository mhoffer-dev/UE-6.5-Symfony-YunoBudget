{% extends 'base.html.twig' %}

{% block title %}Nouvelle Transaction — YunoBudget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 text-white">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_transaction_index') }}" class="text-zinc-400 hover:text-white transition-colors text-base font-mono">
            &larr;
        </a>
        <h1 class="text-xs font-medium tracking-tight text-zinc-400">Ajouter une transaction</h1>
    </div>

    <!-- Section du Titre / Sous-titre épurée -->
    <div class="text-center py-6">
        <h1 class="text-2xl font-semibold tracking-tight text-white">Nouveau mouvement</h1>
        <p class="text-xs text-zinc-500 mt-1">Enregistrez un revenu ou une dépense.</p>
        <div class="w-10 h-[1px] bg-zinc-800 mx-auto mt-3"></div>
    </div>

    <!-- Formulaire (Champs compacts + Bouton Enregistrer inclus) -->
    <div class="text-sm">
        {# On passe explicitement 'transaction': transaction pour éviter l'erreur d'ID #}
        {{ include('transaction/_form.html.twig', {
            'button_label': 'Créer la transaction',
            'transaction': transaction
        }) }}
    </div>
    
</div>
{% endblock %}