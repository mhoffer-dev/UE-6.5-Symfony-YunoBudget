{% extends 'base.html.twig' %}

{% block title %}Yuno - Transactions{% endblock %}

{% block body %}
<div class="space-y-6">
    <!-- Header avec bouton d'action principal -->
    <div class="flex justify-between items-center pb-4 border-b border-[#2D2D31]">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight">Transactions Récentes</h1>
            <p class="text-sm text-zinc-400">Suivez et gérez l'ensemble de vos flux financiers.</p>
        </div>
        <a href="{{ path('app_transaction_new') }}" style="background-color: #FFFFFF; color: #0B0B0C;" class="px-4 py-2 rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity">
            + Ajouter une transaction
        </a>
    </div>

    <!-- Tableau Obsidian Style -->
    <div class="overflow-x-auto rounded-xl border border-[#2D2D31]" style="background-color: #161618;">
        <table class="min-w-full divide-y divide-[#2D2D31] text-left text-sm">
            <thead>
                <tr class="text-zinc-400 text-xs uppercase tracking-wider bg-zinc-900/50">
                    <th class="px-6 py-4 font-semibold">Date</th>
                    <th class="px-6 py-4 font-semibold">Nom / Description</th>
                    <th class="px-6 py-4 font-semibold">Catégorie</th>
                    <th class="px-6 py-4 font-semibold">Moyen de Paiement</th>
                    <th class="px-6 py-4 font-semibold text-right">Montant</th>
                    <th class="px-6 py-4 font-semibold text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#2D2D31]">
                {% for transaction in transactions %}
                    <tr class="hover:bg-zinc-800/30 transition-colors">
                        <!-- CORRECTION : date_transaction -> dateTransaction -->
                        <td class="px-6 py-4 text-zinc-400">
                            {{ transaction.dateTransaction ? transaction.dateTransaction|date('d/m/Y H:i') : '' }}
                        </td>
                        
                        <!-- CORRECTION : libelle_transaction -> libelleTransaction -->
                        <td class="px-6 py-4 font-medium text-white">
                            {{ transaction.libelleTransaction }}
                        </td>
                        
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-zinc-800 text-zinc-300 border border-zinc-700">
                                {{ transaction.categorie ? transaction.categorie.nom : 'Sans catégorie' }}
                            </span>
                        </td>
                        <td>
                            {# 🛡️ Protection absolue : on teste si l'objet existe ET si son ID est valide et supérieur à 0 #}
                            {% if transaction.moyenPaiement and transaction.moyenPaiement.id is defined and transaction.moyenPaiement.id > 0 %}
                                {{ transaction.moyenPaiement.nom }}
                            {% else %}
                                <span class="text-muted" style="font-style: italic;">Non spécifié</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-right font-semibold {% if transaction.montant < 0 %}text-red-400{% else %}text-green-400{% endif %}">
                            {{ transaction.montant|number_format(2, ',', ' ') }} €
                        </td>
                        <td class="px-6 py-4 text-center space-x-3">
                            <a href="{{ path('app_transaction_edit', {'id': transaction.id}) }}" class="text-zinc-400 hover:text-white transition-colors">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-zinc-500">
                            Aucune transaction enregistrée pour le moment.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}