{% extends 'base.html.twig' %}

{% block title %}Modifier mon mot de passe — Yuno Budget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 mt-6">
    <h2 class="text-2xl font-bold mb-2 text-[var(--text-primary)] flex items-center gap-2">
        <span>🔑</span> Changer de mot de passe
    </h2>
    <p class="text-sm text-[var(--text-secondary)] mb-6">Protégez votre compte avec un mot de passe sécurisé et unique.</p>

    {% for message in app.flashes('success') %}
        <div class="p-4 mb-6 rounded-xl bg-emerald-500/15 border border-emerald-500/30 text-emerald-500 font-medium text-sm">
            {{ message }}
        </div>
    {% endfor %}

    {% if not form.vars.valid %}
        <div class="p-4 mb-6 rounded-xl bg-red-500/15 border border-red-500/30 text-red-500 text-sm">
            {{ form_errors(form) }}
            {{ form_errors(form.plainPassword) }}
        </div>
    {% endif %}

    <div class="glass-panel p-6 rounded-2xl">
        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
            <div>
                {{ form_label(form.oldPassword) }}
                {{ form_widget(form.oldPassword) }}
                <div class="text-xs text-pink-500 mt-1">{{ form_errors(form.oldPassword) }}</div>
            </div>
            
            <div>
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first) }}
            </div>
            
            <div>
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second) }}
            </div>
            
            <button type="submit" class="btn-gradient w-full py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider shadow-md cursor-pointer mt-4">
                Mettre à jour le mot de passe
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}