{% extends 'base.html.twig' %}

{% block title %}Modifier mon mot de passe — Yuno{% endblock %}

{% block body %}
<div class="container mt-5" style="max-width: 600px; color: #fff; margin: 0 auto; padding: 20px;">
    <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span>🔑</span> Changer de mot de passe
    </h2>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="background: #1c3d27; color: #2ecc71; border: 1px solid #2ecc71; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
            {{ message }}
        </div>
    {% endfor %}

    {# 🛡️ Zone d'affichage des erreurs globales du formulaire (ex: Token CSRF invalide) #}
    {% if not form.vars.valid %}
        <div class="text-sm text-red-400 bg-red-950/30 border border-red-900/50 p-3 rounded-lg mb-4">
            {{ form_errors(form) }}
            {# 🔥 Affiche l'erreur si les deux mots de passe ne correspondent pas #}
            {{ form_errors(form.plainPassword) }} 
        </div>
    {% endif %}

    <div style="background: #161618; padding: 30px; border-radius: 12px; border: 1px solid #2D2D31;">
        {{ form_start(form) }}
            {%- set input_class = 'w-full rounded-lg border border-[#2D2D31] bg-[#1F1F22] text-white px-3 py-2.5 text-sm focus:outline-none focus:border-zinc-500 transition-all' -%}
            
            <div class="mb-4">
                {{ form_label(form.oldPassword) }}
                {{ form_widget(form.oldPassword, { 'attr': {'class': input_class} }) }}
                <div class="text-xs text-red-400 mt-1">{{ form_errors(form.oldPassword) }}</div>
            </div>
            
            <div class="mb-4">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first, { 'attr': {'class': input_class} }) }}
            </div>
            
            <div class="mb-4">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second, { 'attr': {'class': input_class} }) }}
            </div>
            
            <button type="submit" class="w-full sm:w-auto bg-amber-400 hover:bg-amber-500 text-black font-bold py-2.5 px-5 rounded-xl text-xs uppercase tracking-wider transition-all mt-4">
                Mettre à jour le mot de passe
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}