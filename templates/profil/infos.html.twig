{% extends 'base.html.twig' %}

{% block title %}Informations personnelles — Yuno{% endblock %}

{% block body %}
<div class="container mt-5" style="max-width: 600px; color: #fff; margin: 0 auto; padding: 20px;">
    <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span>👤</span> Informations personnelles
    </h2>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="background: #1c3d27; color: #2ecc71; border: 1px solid #2ecc71; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
            {{ message }}
        </div>
    {% endfor %}

    <div style="background: #161618; padding: 30px; border-radius: 12px; border: 1px solid #2D2D31;">
        {{ form_start(form) }}
            <div class="mb-4">
                {{ form_label(form.email) }}
                {# On force les classes Tailwind pour le fond sombre et le texte blanc #}
                {{ form_widget(form.email, { 'attr': {'class': 'w-full rounded-lg border border-[#2D2D31] bg-[#1F1F22] text-white px-3 py-2.5 text-sm focus:outline-none focus:border-zinc-500 transition-all'} }) }}
                {{ form_errors(form.email) }}
            </div>
            
            <button type="submit" class="w-full sm:w-auto bg-amber-400 hover:bg-amber-500 text-black font-bold py-2.5 px-5 rounded-xl text-xs uppercase tracking-wider transition-all mt-4">
                Enregistrer les modifications
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}