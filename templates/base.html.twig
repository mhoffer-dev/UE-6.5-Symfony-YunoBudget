<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}YunoBudget{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>💰</text></svg>">
        
        {# CDN Tailwind #}
        <script src="https://cdn.tailwindcss.com"></script>
        
        <style>
            :root {
                --bg-main: #0B0B0C;
                --card-bg: #161618;
                --input-bg: #1F1F22;
                --border-color: #2D2D31;
                --text-primary: #FFFFFF;
                --text-secondary: #8E8E93;
            }

            /* Donne du style à tous les blocs de champs (label + input) */
            form > div {
                margin-bottom: 1.25rem;
            }
            /* Style global des labels adapté à la maquette */
            label {
                display: block;
                font-size: 11px !important;
                text-transform: uppercase;
                font-weight: 600;
                letter-spacing: 0.5px;
                color: var(--text-secondary);
                margin-bottom: 0.5rem;
            }
            /* Style Obsidian global des inputs du site */
            input[type="text"], input[type="number"], input[type="datetime-local"], select {
                width: 100%;
                border-radius: 0.5rem;
                border: 1px solid var(--border-color);
                padding: 0.625rem 0.875rem;
                background-color: var(--input-bg);
                color: var(--text-primary);
                font-size: 0.875rem;
                transition: all 0.2s;
            }
            /* Focus épuré Obsidian */
            input:focus, select:focus {
                outline: none;
                border-color: #55555A;
                box-shadow: none;
            }
        </style>
    </head>
    
    {# Application globale du fond ultra sombre de la maquette #}
    <body class="text-white font-sans min-h-screen flex flex-col justify-between" style="background-color: #0B0B0C;">
        
        <div class="flex flex-col flex-grow">
            {# On n'affiche la barre de navigation QUE si on n'est PAS sur login ou register #}
            {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
                <nav style="background-color: #161618; border-bottom: 1px solid #2D2D31;" class="text-white shadow-md w-full">
                    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="flex items-center h-16 w-full">
                            
                            {# --- BLOC GAUCHE : Logo + Liens --- #}
                            <div class="flex items-center space-x-8 flex-shrink-0">
                                <span class="font-bold text-xl tracking-tight">💰 YunoBudget</span>
                                <div class="flex space-x-4">
                                    <a href="{{ path('app_transaction_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Transactions</a>
                                    <a href="{{ path('app_categorie_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Catégories</a>
                                    <a href="{{ path('app_moyen_paiement_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Moyens de Paiement</a>
                                    <a href="{{ path('app_stats_annuel') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors text-amber-400">Bilan Annuel</a>
                                </div>
                            </div>

                            {# --- BLOC DROITE : Poussé de force tout à droite avec ml-auto --- #}
                            <div class="flex items-center space-x-6 ml-auto flex-shrink-0">
                                {% if app.user %}
                                    {# Profil Utilisateur Premium Propre transformé en Menu Déroulant #}
                                    <div class="relative inline-block text-left id-profile-container">
                                        <button onclick="toggleProfileMenu()" class="flex items-center space-x-3 bg-zinc-900/50 hover:bg-zinc-800/80 border border-[#2D2D31] px-3 py-1.5 rounded-xl transition-all cursor-pointer focus:outline-none">
                                            <div class="w-7 h-7 rounded-full bg-zinc-800 flex items-center justify-center border border-zinc-700">
                                                <svg class="w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                            </div>
                                            <span class="text-xs font-semibold text-zinc-300 tracking-wide">
                                                {{ app.user.email }}
                                            </span>
                                            {# Petite roue dentée fine (outline style) #}
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="text-zinc-400 opacity-70" viewBox="0 0 16 16">
                                                <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                                                <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.767-.417 1.6.416 1.183 1.183l-.16.291a1.873 1.873 0 0 0 1.115 2.693l.319.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.417.766-.416 1.6-1.183 1.183l-.292-.16a1.873 1.873 0 0 0-2.693 1.115l-.094.319c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.693-1.115l-.291.16c-.767.417-1.6-.416-1.183-1.183l.16-.291a1.873 1.873 0 0 0-1.115-2.693l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094a1.873 1.873 0 0 0 1.115-2.693l-.16-.291c-.417-.766.416-1.6 1.183-1.183l.292.16a1.873 1.873 0 0 0 2.693-1.115z"/>
                                            </svg>
                                        </button>

                                        {# Menu Contextuel #}
                                        <div id="profileDropdown" class="hidden absolute right-0 mt-2 w-52 origin-top-right rounded-xl bg-[#161618] border border-[#2D2D31] shadow-xl ring-1 ring-black ring-opacity-5 focus:outline-none z-50 py-1.5">
                                            <a href="{{ path('app_profil_infos') }}" class="flex items-center px-4 py-2 text-xs text-zinc-300 hover:bg-zinc-800 hover:text-white transition-colors">
                                                <span class="mr-2">👤</span> Informations personnelles
                                            </a>
                                            <a href="{{ path('app_profil_password') }}" class="flex items-center px-4 py-2 text-xs text-zinc-300 hover:bg-zinc-800 hover:text-white transition-colors">
                                                <span class="mr-2">🔑</span> Changer de mot de passe
                                            </a>
                                        </div>
                                    </div>

                                    {# Bouton Log Out #}
                                    <a href="{{ path('app_logout') }}"
                                    style="border: 1px solid #2D2D31;"
                                    class="hover:bg-red-950/30 hover:border-red-900/50 hover:text-red-400 px-3 py-2 rounded-xl text-xs font-semibold uppercase tracking-wider text-zinc-400 transition-all">
                                        Log out
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="hover:text-zinc-300 text-sm font-medium transition-colors">
                                        Connexion
                                    </a>
                                    <a href="{{ path('app_register') }}" style="background-color: #FFFFFF; color: #0B0B0C;" class="px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider hover:opacity-90 transition-opacity">
                                        Inscription
                                    </a>
                                {% endif %}
                            </div>

                        </div>
                    </div>
                </nav>
            {% endif %}

            {# Contenu principal adaptatif #}
            <main class="{% if app.current_route != 'app_login' and app.current_route != 'app_register' %}max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8{% endif %}">
                {% block body %}{% endblock %}
            </main>
        </div>

        {# On n'affiche le footer de base QUE si on n'est PAS sur login ou register #}
        {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
            <footer style="background-color: #161618; border-top: 1px solid #2D2D31;" class="text-zinc-500 text-center py-5 text-sm w-full">
                &copy; {{ "now"|date("Y") }} YunoBudget &bull; Obsidian Precision
            </footer>
        {% endif %}

        {# Script pour le comportement du Menu Déroulant #}
        <script>
            function toggleProfileMenu() {
                const dropdown = document.getElementById('profileDropdown');
                dropdown.classList.toggle('hidden');
            }

            // Fermeture automatique si on clique à l'extérieur du profil
            window.addEventListener('click', function(e) {
                const container = document.querySelector('.id-profile-container');
                if (container && !container.contains(e.target)) {
                    document.getElementById('profileDropdown').classList.add('hidden');
                }
            });
        </script>
    </body>
</html>