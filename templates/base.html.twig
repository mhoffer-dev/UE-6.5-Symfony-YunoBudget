<!DOCTYPE html>
<html data-theme="dark">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Yuno Budget - Fintech Intelligence{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>⚡</text></svg>">
        
        {# Google Fonts - Outfit & Inter #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        
        {# CDN Tailwind #}
        <script src="https://cdn.tailwindcss.com"></script>
        
        <script>
            // Initialisation immédiate du thème pour éviter le flash
            (function() {
                const savedTheme = localStorage.getItem('yuno_theme') || 'dark';
                document.documentElement.setAttribute('data-theme', savedTheme);
            })();
        </script>

        <style>
            :root, [data-theme="dark"] {
                --bg-main: #0B0D12;
                --bg-secondary: #121620;
                --card-bg: rgba(22, 26, 38, 0.7);
                --input-bg: rgba(15, 18, 26, 0.85);
                --border-color: rgba(255, 255, 255, 0.08);
                --border-glow: rgba(139, 92, 246, 0.3);
                --text-primary: #FFFFFF;
                --text-secondary: #94A3B8;
                --accent-color: #8B5CF6;
                --accent-gradient: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #D946EF 100%);
                --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
                --nav-bg: rgba(18, 22, 32, 0.8);
                --badge-bg: rgba(139, 92, 246, 0.15);
                --badge-text: #A855F7;
            }

            [data-theme="light-violet"] {
                --bg-main: #F4F2FF;
                --bg-secondary: #EBE5FF;
                --card-bg: rgba(255, 255, 255, 0.75);
                --input-bg: rgba(255, 255, 255, 0.95);
                --border-color: rgba(139, 92, 246, 0.18);
                --border-glow: rgba(139, 92, 246, 0.5);
                --text-primary: #1E1B4B;
                --text-secondary: #64748B;
                --accent-color: #7C3AED;
                --accent-gradient: linear-gradient(135deg, #7C3AED 0%, #A855F7 50%, #EC4899 100%);
                --glass-shadow: 0 8px 32px 0 rgba(124, 58, 237, 0.12);
                --nav-bg: rgba(255, 255, 255, 0.85);
                --badge-bg: rgba(124, 58, 237, 0.12);
                --badge-text: #6D28D9;
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-primary);
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                transition: background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), color 0.4s ease;
            }

            h1, h2, h3, h4, .font-heading {
                font-family: 'Outfit', sans-serif;
            }

            /* Glassmorphism Classes */
            .glass-panel {
                background: var(--card-bg);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid var(--border-color);
                box-shadow: var(--glass-shadow);
                transition: all 0.3s ease;
            }

            .glass-nav {
                background: var(--nav-bg);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border-bottom: 1px solid var(--border-color);
            }

            /* Responsive Table & Glassmorphism Components */
            .table-container {
                background: var(--card-bg);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid var(--border-color);
                border-radius: 1rem;
                overflow: hidden;
                box-shadow: var(--glass-shadow);
            }

            .fintech-table {
                width: 100%;
                border-collapse: collapse;
                text-align: left;
                font-size: 0.875rem;
            }

            .fintech-table thead {
                background: var(--bg-secondary);
                border-bottom: 1px solid var(--border-color);
            }

            .fintech-table th {
                color: var(--text-secondary);
                font-size: 0.75rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                padding: 1rem 1.5rem;
            }

            .fintech-table td {
                padding: 1rem 1.5rem;
                color: var(--text-primary);
                border-bottom: 1px solid var(--border-color);
            }

            .fintech-table tr:last-child td {
                border-bottom: none;
            }

            .fintech-table tbody tr {
                transition: background-color 0.2s ease;
            }

            .fintech-table tbody tr:hover {
                background-color: var(--border-color);
            }

            .text-primary-themed { color: var(--text-primary) !important; }
            .text-secondary-themed { color: var(--text-secondary) !important; }
            .border-themed { border-color: var(--border-color) !important; }
            .bg-themed { background-color: var(--card-bg) !important; }

            form > div {
                margin-bottom: 1.25rem;
            }

            label {
                display: block;
                font-size: 11px !important;
                text-transform: uppercase;
                font-weight: 700;
                letter-spacing: 0.8px;
                color: var(--text-secondary);
                margin-bottom: 0.5rem;
            }

            input[type="text"], input[type="number"], input[type="datetime-local"], select, input[type="email"], input[type="password"] {
                width: 100%;
                border-radius: 0.75rem;
                border: 1px solid var(--border-color);
                padding: 0.75rem 1rem;
                background-color: var(--input-bg);
                color: var(--text-primary);
                font-size: 0.9rem;
                transition: all 0.25s ease;
            }

            input:focus, select:focus {
                outline: none;
                border-color: var(--accent-color);
                box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
            }

            .btn-gradient {
                background: var(--accent-gradient);
                color: #ffffff !important;
                font-weight: 600;
                border-radius: 0.75rem;
                transition: all 0.3s ease;
                box-shadow: 0 4px 15px rgba(139, 92, 246, 0.35);
            }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 22px rgba(139, 92, 246, 0.5);
            }
        </style>
    </head>
    
    <body class="min-h-screen flex flex-col justify-between">
        
        <div class="flex flex-col flex-grow relative z-10">
            {# On n'affiche la barre de navigation QUE si on n'est PAS sur login ou register #}
            {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
                <nav class="glass-nav sticky top-0 z-50 w-full transition-all">
                    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="flex items-center justify-between h-16 w-full">
                            
                            {# --- BLOC GAUCHE : Logo + Liens --- #}
                            <div class="flex items-center space-x-8 flex-shrink-0">
                                <a href="{{ path('app_home') }}" class="flex items-center space-x-2 font-heading font-extrabold text-xl tracking-tight">
                                    <span class="w-8 h-8 rounded-lg bg-gradient-to-tr from-violet-600 to-fuchsia-500 flex items-center justify-center text-white text-base shadow-lg shadow-violet-500/30">⚡</span>
                                    <span class="bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">YUNO BUDGET</span>
                                </a>
                                <div class="hidden md:flex space-x-2">
                                    <a href="{{ path('app_transaction_index') }}" class="hover:bg-violet-500/10 hover:text-violet-400 px-3 py-2 rounded-lg text-sm font-medium transition-all">Transactions</a>
                                    <a href="{{ path('app_categorie_index') }}" class="hover:bg-violet-500/10 hover:text-violet-400 px-3 py-2 rounded-lg text-sm font-medium transition-all">Catégories</a>
                                    <a href="{{ path('app_moyen_paiement_index') }}" class="hover:bg-violet-500/10 hover:text-violet-400 px-3 py-2 rounded-lg text-sm font-medium transition-all">Moyens de Paiement</a>
                                    <a href="{{ path('app_stats_annuel') }}" class="hover:bg-amber-500/10 px-3 py-2 rounded-lg text-sm font-semibold transition-all text-amber-400">📊 Bilan Annuel</a>
                                </div>
                            </div>

                            {# --- BLOC DROITE : Thème Toggle + Profil --- #}
                            <div class="flex items-center space-x-4 flex-shrink-0">
                                
                                {# Bouton de bascule du thème #}
                                <button onclick="toggleTheme()" class="theme-toggle-btn flex items-center space-x-2 px-3.5 py-1.5 rounded-full border border-[var(--border-color)] bg-[var(--input-bg)] text-xs font-semibold hover:border-violet-500 transition-all shadow-sm cursor-pointer" title="Changer de thème">
                                    <span>⚡</span> <span class="hidden sm:inline">Thème Violet</span>
                                </button>

                                {% if app.user %}
                                    <div class="relative inline-block text-left id-profile-container">
                                        <button onclick="toggleProfileMenu()" class="flex items-center space-x-3 bg-[var(--input-bg)] hover:border-violet-500 border border-[var(--border-color)] px-3 py-1.5 rounded-xl transition-all cursor-pointer focus:outline-none shadow-sm">
                                            <div class="w-7 h-7 rounded-full bg-gradient-to-tr from-violet-600 to-pink-500 flex items-center justify-center text-white text-xs font-bold shadow">
                                                {{ app.user.email|slice(0, 2)|upper }}
                                            </div>
                                            <span class="text-xs font-semibold tracking-wide hidden sm:inline">
                                                {{ app.user.email }}
                                            </span>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="opacity-70" viewBox="0 0 16 16">
                                                <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                                                <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.767-.417 1.6.416 1.183 1.183l-.16.291a1.873 1.873 0 0 0 1.115 2.693l.319.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.417.766-.416 1.6-1.183 1.183l-.292-.16a1.873 1.873 0 0 0-2.693 1.115l-.094.319c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.693-1.115l-.291.16c-.767.417-1.6-.416-1.183-1.183l.16-.291a1.873 1.873 0 0 0-1.115-2.693l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094a1.873 1.873 0 0 0 1.115-2.693l-.16-.291c-.417-.766.416-1.6 1.183-1.183l.292.16a1.873 1.873 0 0 0 2.693-1.115z"/>
                                            </svg>
                                        </button>

                                        <div id="profileDropdown" class="hidden absolute right-0 mt-2 w-52 origin-top-right rounded-xl glass-panel focus:outline-none z-50 py-2">
                                            <a href="{{ path('app_profil_infos') }}" class="flex items-center px-4 py-2 text-xs hover:bg-violet-500/20 transition-colors">
                                                <span class="mr-2">👤</span> Informations personnelles
                                            </a>
                                            <a href="{{ path('app_profil_password') }}" class="flex items-center px-4 py-2 text-xs hover:bg-violet-500/20 transition-colors">
                                                <span class="mr-2">🔑</span> Changer de mot de passe
                                            </a>
                                        </div>
                                    </div>

                                    <a href="{{ path('app_logout') }}" class="hover:bg-red-500/20 hover:border-red-500 border border-[var(--border-color)] px-3 py-1.5 rounded-xl text-xs font-semibold uppercase tracking-wider text-red-400 transition-all">
                                        Log out
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="hover:text-violet-400 text-sm font-medium transition-colors">
                                        Connexion
                                    </a>
                                    <a href="{{ path('app_register') }}" class="btn-gradient px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider">
                                        Inscription
                                    </a>
                                {% endif %}
                            </div>

                        </div>
                    </div>
                </nav>
            {% endif %}

            <main class="{% if app.current_route != 'app_login' and app.current_route != 'app_register' %}max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8{% endif %}">
                {% block body %}{% endblock %}
            </main>
        </div>

        {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
            <footer class="border-t border-[var(--border-color)] text-center py-6 text-xs text-[var(--text-secondary)] w-full relative z-10 font-medium">
                &copy; {{ "now"|date("Y") }} <span class="text-[var(--text-primary)] font-bold">YUNO BUDGET</span> &bull; <a href="https://developpement-web-communication-apprentissages.fr/" target="_blank" rel="noopener noreferrer" class="text-violet-400 hover:text-pink-400 underline transition-colors font-semibold">Université de Strasbourg</a> LPDWCA 2025-2026
            </footer>
        {% endif %}

        <script>
            function toggleTheme() {
                const current = document.documentElement.getAttribute('data-theme') || 'dark';
                const next = current === 'dark' ? 'light-violet' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('yuno_theme', next);
                updateThemeToggleUI();
            }

            function updateThemeToggleUI() {
                const isLight = document.documentElement.getAttribute('data-theme') === 'light-violet';
                document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
                    btn.innerHTML = isLight 
                        ? '<span>🌙</span> <span class="hidden sm:inline">Thème Sombre</span>' 
                        : '<span>⚡</span> <span class="hidden sm:inline">Thème Violet</span>';
                });
            }

            document.addEventListener('DOMContentLoaded', updateThemeToggleUI);

            function toggleProfileMenu() {
                const dropdown = document.getElementById('profileDropdown');
                if (dropdown) dropdown.classList.toggle('hidden');
            }

            window.addEventListener('click', function(e) {
                const container = document.querySelector('.id-profile-container');
                if (container && !container.contains(e.target)) {
                    const dropdown = document.getElementById('profileDropdown');
                    if (dropdown) dropdown.classList.add('hidden');
                }
            });
        </script>
    </body>
</html>