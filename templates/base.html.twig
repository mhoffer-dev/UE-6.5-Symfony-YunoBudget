<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}YunoBudget{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>💰</text></svg>">
        
        {# CDN Tailwind #}
        <script src="https://cdn.tailwindcss.com"></script>
        
        <style>
            :root {
                --bg-main: #0B0B0C;
                --card-bg: #161618;
                --input-bg: #1F1F22;
                --border-color: #2D2D31;
                --text-primary: #FFFFFF;
                --text-secondary: #8E8E93;
            }

            /* Donne du style à tous les blocs de champs (label + input) */
            form > div {
                margin-bottom: 1.25rem;
            }
            /* Style global des labels adapté à la maquette */
            label {
                display: block;
                font-size: 11px !important;
                text-transform: uppercase;
                font-weight: 600;
                letter-spacing: 0.5px;
                color: var(--text-secondary);
                margin-bottom: 0.5rem;
            }
            /* Style Obsidian global des inputs du site */
            input[type="text"], input[type="number"], input[type="datetime-local"], select {
                width: 100%;
                border-radius: 0.5rem;
                border: 1px solid var(--border-color);
                padding: 0.625rem 0.875rem;
                background-color: var(--input-bg);
                color: var(--text-primary);
                font-size: 0.875rem;
                transition: all 0.2s;
            }
            /* Focus épuré Obsidian */
            input:focus, select:focus {
                outline: none;
                border-color: #55555A;
                box-shadow: none;
            }
        </style>
    </head>
    
    {# Application globale du fond ultra sombre de la maquette #}
    <body class="text-white font-sans min-h-screen flex flex-col justify-between" style="background-color: #0B0B0C;">
        
        <div class="flex flex-col flex-grow">
            {# On n'affiche la barre de navigation QUE si on n'est PAS sur login ou register #}
            {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
                <nav style="background-color: #161618; border-bottom: 1px solid #2D2D31;" class="text-white shadow-md w-full">
                    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="flex items-center h-16 w-full">
                            
                            {# --- BLOC GAUCHE : Logo + Liens --- #}
                            <div class="flex items-center space-x-8 flex-shrink-0">
                                <span class="font-bold text-xl tracking-tight">💰 Yuno</span>
                                <div class="flex space-x-4">
                                    <a href="{{ path('app_transaction_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Transactions</a>
                                    <a href="{{ path('app_categorie_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Catégories</a>
                                    <a href="{{ path('app_moyen_paiement_index') }}" class="hover:bg-zinc-800 px-3 py-2 rounded-md text-sm font-medium transition-colors">Moyens de Paiement</a>
                                </div>
                            </div>

                            {# --- BLOC DROITE : Poussé de force tout à droite avec ml-auto --- #}
                            <div class="flex items-center space-x-6 ml-auto flex-shrink-0">
                                {% if app.user %}
                                    {# Profil Utilisateur Premium Propre #}
                                    <div class="flex items-center space-x-3 bg-zinc-900/50 border border-[#2D2D31] px-3 py-1.5 rounded-xl">
                                        <div class="w-7 h-7 rounded-full bg-zinc-800 flex items-center justify-center border border-zinc-700">
                                            <svg class="w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                            </svg>
                                        </div>
                                        <span class="text-xs font-semibold text-zinc-300 tracking-wide">
                                            {{ app.user.email }}
                                        </span>
                                    </div>

                                    {# Bouton Log Out #}
                                    <a href="{{ path('app_logout') }}"
                                    style="border: 1px solid #2D2D31;"
                                    class="hover:bg-red-950/30 hover:border-red-900/50 hover:text-red-400 px-3 py-2 rounded-xl text-xs font-semibold uppercase tracking-wider text-zinc-400 transition-all">
                                        Log out
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="hover:text-zinc-300 text-sm font-medium transition-colors">
                                        Connexion
                                    </a>
                                    <a href="{{ path('app_register') }}" style="background-color: #FFFFFF; color: #0B0B0C;" class="px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider hover:opacity-90 transition-opacity">
                                        Inscription
                                    </a>
                                {% endif %}
                            </div>

                        </div>
                    </div>
                </nav>
            {% endif %}

            {# Contenu principal adaptatif #}
            <main class="{% if app.current_route != 'app_login' and app.current_route != 'app_register' %}max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8{% endif %}">
                {% block body %}{% endblock %}
            </main>
        </div>

        {# On n'affiche le footer de base QUE si on n'est PAS sur login ou register #}
        {% if app.current_route != 'app_login' and app.current_route != 'app_register' %}
            <footer style="background-color: #161618; border-top: 1px solid #2D2D31;" class="text-zinc-500 text-center py-5 text-sm w-full">
                &copy; {{ "now"|date("Y") }} YunoBudget &bull; Obsidian Precision
            </footer>
        {% endif %}
    </body>
</html>