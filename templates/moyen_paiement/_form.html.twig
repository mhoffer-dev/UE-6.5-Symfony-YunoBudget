{{ form_start(form, {'attr': {'class': 'space-y-2.5'}}) }}
    
    {# 1. Rendu des inputs principaux #}
    <div>
        {{ form_widget(form) }}
    </div>

    {# 2. Groupe d'actions principal #}
    <div class="flex flex-col space-y-3 pt-4">
        <button type="submit" class="w-full bg-white text-black py-2.5 px-4 rounded-xl font-semibold text-xs hover:opacity-90 transition-opacity uppercase tracking-wider shadow-sm">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>

{{ form_end(form) }}

{# 3. Formulaire de Suppression Indépendant (Uniquement à l'édition) #}
{% if moyen_paiement is defined and moyen_paiement.id is not null %}
    <form method="post" action="{{ path('app_moyen_paiement_delete', {'id': moyen_paiement.id}) }}" onsubmit="return confirm('Confirmer la suppression définitive de ce moyen de paiement ?');" class="mt-3">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ moyen_paiement.id) }}">
        
        <button type="submit" class="w-full bg-transparent border border-red-500/20 text-red-400 py-2.5 px-4 rounded-xl font-medium text-xs hover:bg-red-500/10 hover:border-red-500/40 transition-all uppercase tracking-wider text-center">
            Supprimer le moyen de paiement
        </button>
    </form>
{% endif %} {# <-- C'était cette ligne qui manquait ou s'était mal fermée ! #}