{% extends 'base.html.twig' %}

{% block title %}Nouveau Moyen de Paiement — Yuno Budget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_moyen_paiement_index') }}" class="text-[var(--text-secondary)] hover:text-violet-500 transition-colors text-base font-mono font-bold">
            &larr; Retour
        </a>
    </div>

    <!-- Section du Titre -->
    <div class="text-center py-6">
        <h1 class="text-2xl font-semibold tracking-tight text-[var(--text-primary)]">Nouveau moyen</h1>
        <p class="text-xs text-[var(--text-secondary)] mt-1">Ajoutez un compte, une carte ou un portefeuille (ex: PayPal, CB).</p>
        <div class="w-12 h-0.5 bg-gradient-to-r from-violet-500 to-pink-500 mx-auto mt-3 rounded-full"></div>
    </div>

    <!-- Formulaire dans une carte en verre -->
    <div class="glass-panel p-6 rounded-2xl text-sm">
        {{ include('moyen_paiement/_form.html.twig', {
            'button_label': 'Créer le moyen de paiement',
            'moyen_paiement': moyen_paiement
        }) }}
    </div>
    
</div>
{% endblock %}