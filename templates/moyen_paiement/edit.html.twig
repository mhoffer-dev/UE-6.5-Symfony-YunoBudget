{% extends 'base.html.twig' %}

{% block title %}Modifier le Moyen de Paiement — YunoBudget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 text-white">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_moyen_paiement_index') }}" class="text-zinc-400 hover:text-white transition-colors text-base font-mono">
            &larr;
        </a>
        <h1 class="text-xs font-medium tracking-tight text-zinc-400">Modifier le moyen de paiement</h1>
    </div>

    <!-- Section Titre Épuré -->
    <div class="text-center py-6">
        <h1 class="text-2xl font-semibold tracking-tight text-white">{{ moyen_paiement.nom }}</h1>
        <p class="text-xs text-zinc-500 mt-1">Ajustez les détails de ce moyen de paiement.</p>
        <div class="w-10 h-[1px] bg-zinc-800 mx-auto mt-3"></div>
    </div>

    <!-- Formulaire -->
    <div class="text-sm">
        {{ include('moyen_paiement/_form.html.twig', {
            'button_label': 'Enregistrer les modifications',
            'moyen_paiement': moyen_paiement
        }) }}
    </div>
    
</div>
{% endblock %}