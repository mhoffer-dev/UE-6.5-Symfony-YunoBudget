{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <h1 class="text-3xl font-bold text-gray-900">👁️ Détails du moyen de paiement</h1>
        <a href="{{ path('app_moyen_paiement_index') }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-900">
            &larr; Retour à la liste
        </a>
    </div>

    <div class="bg-white shadow sm:rounded-lg overflow-hidden border border-gray-100">
        <div class="px-6 py-5 bg-gray-50 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900">💳 {{ moyen_paiement.nom }}</h3>
        </div>
        <div class="border-t border-gray-200 px-6 py-5">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
                <div>
                    <dt class="text-sm font-medium text-gray-500">Type de carte / compte</dt>
                    <dd class="mt-1 text-sm text-gray-900 uppercase tracking-wider font-semibold">{{ moyen_paiement.type.value }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Établissement bancaire</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ moyen_paiement.libelleBanque ?? 'Non spécifié' }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-sm font-medium text-gray-500">Numéro masqué</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-mono tracking-widest">{{ moyen_paiement.numeroMasque ?? '**** **** **** ****' }}</dd>
                </div>
            </dl>
        </div>
    </div>

    <div class="mt-6 flex items-center justify-between">
        <a href="{{ path('app_moyen_paiement_edit', {'id': moyen_paiement.id}) }}" class="inline-flex justify-center px-4 py-2 text-sm font-medium rounded-md shadow-sm text-white bg-amber-500 hover:bg-amber-600">
            ✏️ Modifier
        </a>
        {{ include('moyen_paiement/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}