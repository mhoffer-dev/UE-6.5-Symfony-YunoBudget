{% extends 'base.html.twig' %}

{% block title %}Moyens de Paiement - YunoBudget{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8 pb-4 border-b border-[#2D2D31]">
    <div>
        <h1 class="text-2xl font-semibold tracking-tight text-white">Vos Moyens de Paiement</h1>
        <p class="mt-2 text-sm text-zinc-400">Configurez vos cartes, comptes bancaires ou portefeuilles numériques.</p>
    </div>
    <div class="mt-4 sm:mt-0">
        <a href="{{ path('app_moyen_paiement_new') }}" style="background-color: #FFFFFF; color: #0B0B0C;" class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-md shadow-sm hover:opacity-90 transition-opacity">
            + Ajouter un moyen de paiement
        </a>
    </div>
</div>

<div class="flex flex-col mt-6">
    <div class="overflow-x-auto border border-[#2D2D31] rounded-xl" style="background-color: #161618;">
        <table class="min-w-full divide-y divide-[#2D2D31] text-left text-sm">
            <thead>
                <tr class="text-zinc-400 text-xs uppercase tracking-wider bg-zinc-900/50">
                    <th class="px-6 py-4 font-semibold">Nom</th>
                    <th class="px-6 py-4 font-semibold">Type</th>
                    <th class="px-6 py-4 font-semibold">Banque</th>
                    <th class="px-6 py-4 font-semibold">N° Masqué</th>
                    <th class="px-6 py-4 font-semibold text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#2D2D31]">
            {% for moyen_paiement in moyen_paiements %}
                <tr class="hover:bg-zinc-800/30 transition-colors">
                    <td class="px-6 py-4 text-sm font-semibold text-white">💳 {{ moyen_paiement.nom }}</td>
                    <td class="px-6 py-4 text-sm">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-zinc-800 text-zinc-300 border border-zinc-700 uppercase tracking-wider">
                            {{ moyen_paiement.type.value }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-zinc-400">{{ moyen_paiement.libelleBanque ?? 'N/A' }}</td>
                    <td class="px-6 py-4 text-sm text-zinc-400 font-mono text-xs">{{ moyen_paiement.numeroMasque ?? '**** ****' }}</td>
                    <td class="px-6 py-4 text-sm font-medium text-center">
                        <a href="{{ path('app_moyen_paiement_edit', {'id': moyen_paiement.id}) }}" class="text-zinc-400 hover:text-white transition-colors">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-sm text-zinc-500">Aucun moyen de paiement configuré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}