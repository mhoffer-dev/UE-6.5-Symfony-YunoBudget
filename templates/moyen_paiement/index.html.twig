{% extends 'base.html.twig' %}

{% block title %}Moyens de Paiement - Yuno Budget{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8 pb-4 border-b border-[var(--border-color)]">
    <div>
        <h1 class="text-2xl font-semibold tracking-tight text-[var(--text-primary)]">Vos Moyens de Paiement</h1>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">Configurez vos cartes, comptes bancaires ou portefeuilles numériques.</p>
    </div>
    <div class="mt-4 sm:mt-0">
        <a href="{{ path('app_moyen_paiement_new') }}" class="btn-gradient inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold rounded-xl shadow-sm transition-all">
            + Ajouter un moyen de paiement
        </a>
    </div>
</div>

<div class="flex flex-col mt-6">
    <div class="overflow-x-auto table-container">
        <table class="fintech-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Type</th>
                    <th>Banque</th>
                    <th>N° Masqué</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for moyen_paiement in moyen_paiements %}
                <tr>
                    <td class="font-semibold text-[var(--text-primary)]">💳 {{ moyen_paiement.nom }}</td>
                    <td>
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-violet-500/15 text-violet-500 border border-violet-500/30 uppercase tracking-wider">
                            {{ moyen_paiement.type.value }}
                        </span>
                    </td>
                    <td class="text-[var(--text-secondary)] font-medium">{{ moyen_paiement.libelleBanque ?? 'N/A' }}</td>
                    <td class="text-[var(--text-secondary)] font-mono text-xs">{{ moyen_paiement.numeroMasque ?? '**** ****' }}</td>
                    <td class="font-medium text-center">
                        <a href="{{ path('app_moyen_paiement_edit', {'id': moyen_paiement.id}) }}" class="text-violet-500 hover:text-pink-500 transition-colors font-semibold">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="py-12 text-center text-sm text-[var(--text-secondary)]">Aucun moyen de paiement configuré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}