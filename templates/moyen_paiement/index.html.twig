{% extends 'base.html.twig' %}

{% block title %}Moyens de Paiement - YunoBudget{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">💳 Vos Moyens de Paiement</h1>
        <p class="mt-2 text-sm text-gray-700">Configurez vos cartes, comptes bancaires ou portefeuilles numériques.</p>
    </div>
    <div class="mt-4 sm:mt-0">
        <a href="{{ path('app_moyen_paiement_new') }}" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
            ➕ Ajouter un moyen de paiement
        </a>
    </div>
</div>

<div class="flex flex-col mt-6">
    <div class="overflow-x-auto border border-gray-200 shadow sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nom</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Banque</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">N° Masqué</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
            {% for moyen_paiement in moyen_paiements %}
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 text-sm font-semibold text-gray-900">💳 {{ moyen_paiement.nom }}</td>
                    <td class="px-6 py-4 text-sm">
                        <span class="px-2 py-1 text-xs font-medium rounded bg-gray-100 text-gray-800 uppercase tracking-wider">
                            {{ moyen_paiement.type.value }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500">{{ moyen_paiement.libelleBanque ?? 'N/A' }}</td>
                    <td class="px-6 py-4 text-sm text-gray-500 font-mono text-xs">{{ moyen_paiement.numeroMasque ?? '**** ****' }}</td>
                    <td class="px-6 py-4 text-sm font-medium space-x-3">
                        <a href="{{ path('app_moyen_paiement_show', {'id': moyen_paiement.id}) }}" class="text-indigo-600 hover:text-indigo-900">👁️ Voir</a>
                        <a href="{{ path('app_moyen_paiement_edit', {'id': moyen_paiement.id}) }}" class="text-amber-600 hover:text-amber-900">✏️ Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500 bg-gray-50">Aucun moyen de paiement configuré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}