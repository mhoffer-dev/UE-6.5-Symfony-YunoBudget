{% extends 'base.html.twig' %}

{% block title %}Bilan Annuel {{ annee }} - Yuno Budget{% endblock %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="space-y-8">
    <div class="pb-4 border-b border-[var(--border-color)]">
        <h1 class="text-2xl font-bold tracking-tight text-[var(--text-primary)]">Bilan Annuel — {{ annee }}</h1>
        <p class="text-[var(--text-secondary)] text-sm mt-1">Analyse globale de vos flux financiers de l'année en cours.</p>
    </div>

    {# --- CARTES DE SYNTHÈSE --- #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="glass-panel p-6 rounded-2xl">
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Total Revenus</span>
            <div class="text-3xl font-extrabold text-emerald-500 mt-2">+{{ totalRevenus|number_format(2, ',', ' ') }} €</div>
        </div>
        <div class="glass-panel p-6 rounded-2xl">
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Total Dépenses</span>
            <div class="text-3xl font-extrabold text-pink-500 mt-2">-{{ totalDepenses|number_format(2, ',', ' ') }} €</div>
        </div>
        <div class="glass-panel p-6 rounded-2xl">
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Net Épargné</span>
            <div class="text-3xl font-extrabold mt-2 {{ (totalRevenus - totalDepenses) >= 0 ? 'text-violet-500' : 'text-pink-500' }}">
                {{ (totalRevenus - totalDepenses)|number_format(2, ',', ' ') }} €
            </div>
        </div>
    </div>

    {# --- GRAPHIQUES --- #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 glass-panel p-6 rounded-2xl flex flex-col justify-between">
            <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)] mb-4">Flux Mensuels</h3>
            <div class="w-full h-72">
                <canvas id="chartEvolution"></canvas>
            </div>
        </div>

        <div class="glass-panel p-6 rounded-2xl flex flex-col justify-between">
            <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)] mb-4">Répartition des Dépenses</h3>
            <div class="w-full h-72 flex items-center justify-center">
                <canvas id="chartCategories"></canvas>
            </div>
        </div>
    </div>
</div>

{# --- SCRIPTS CHARTS --- #}
<script>
    const moisLabels = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil', 'Août', 'Sept', 'Oct', 'Nov', 'Déc'];

    // 1. Configuration Chart Évolution (Barres)
    new Chart(document.getElementById('chartEvolution'), {
        type: 'bar',
        data: {
            labels: moisLabels,
            datasets: [
                {
                    label: 'Revenus',
                    data: {{ revenus|json_encode }},
                    backgroundColor: '#10B981', // emerald-500
                    borderRadius: 6
                },
                {
                    label: 'Dépenses',
                    data: {{ depenses|json_encode }},
                    backgroundColor: '#EC4899', // pink-500
                    borderRadius: 6
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#8E8E93', font: { size: 11 } } },
                y: { grid: { color: 'rgba(139, 92, 246, 0.1)' }, ticks: { color: '#8E8E93', font: { size: 11 } } }
            }
        }
    });

    // 2. Configuration Chart Catégories (Doughnut)
    new Chart(document.getElementById('chartCategories'), {
        type: 'doughnut',
        data: {
            labels: {{ categoriesLabels|json_encode|raw }},
            datasets: [{
                data: {{ categoriesData|json_encode }},
                backgroundColor: ['#8B5CF6', '#EC4899', '#10B981', '#F59E0B', '#6366F1', '#3B82F6'],
                borderWidth: 2,
                borderColor: 'transparent'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#8E8E93', font: { size: 11 }, boxWidth: 12, padding: 15 }
                }
            }
        }
    });
</script>
{% endblock %}