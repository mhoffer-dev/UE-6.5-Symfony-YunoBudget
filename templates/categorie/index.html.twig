{% extends 'base.html.twig' %}

{% block title %}Catégories - YunoBudget{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8 pb-4 border-b border-[#2D2D31]">
    <div>
        <h1 class="text-2xl font-semibold tracking-tight text-white">Vos Catégories</h1>
        <p class="mt-2 text-sm text-zinc-400">Gérez vos postes de dépenses et sources de revenus.</p>
    </div>
    <div class="mt-4 sm:mt-0">
        <a href="{{ path('app_categorie_new') }}" style="background-color: #FFFFFF; color: #0B0B0C;" class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold rounded-md shadow-sm hover:opacity-90 transition-opacity">
            + Nouvelle catégorie
        </a>
    </div>
</div>

<div class="flex flex-col mt-6">
    <div class="overflow-x-auto border border-[#2D2D31] rounded-xl" style="background-color: #161618;">
        <table class="min-w-full divide-y divide-[#2D2D31] text-left text-sm">
            <thead>
                <tr class="text-zinc-400 text-xs uppercase tracking-wider bg-zinc-900/50">
                    <th class="px-6 py-4 font-semibold">Nom</th>
                    <th class="px-6 py-4 font-semibold">Type</th>
                    <th class="px-6 py-4 font-semibold text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#2D2D31]">
            {% for categorie in categories %}
                <tr class="hover:bg-zinc-800/30 transition-colors">
                    <td class="px-6 py-4 text-sm font-medium text-white flex items-center space-x-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-zinc-500 border border-zinc-400/20"></span>
                        <span>{{ categorie.nom }}</span>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        {% if categorie.type.value|lower == 'revenu' %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 border border-emerald-500/20 text-emerald-400">
                                💰 Revenu
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-500/10 border border-red-500/20 text-red-400">
                                📉 Dépense
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 text-sm font-medium text-center">
                        <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-12 text-center text-sm text-zinc-500">Aucune catégorie enregistrée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}