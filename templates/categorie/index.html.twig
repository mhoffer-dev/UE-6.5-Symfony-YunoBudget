{% extends 'base.html.twig' %}

{% block title %}Catégories - YunoBudget{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-900"> Vos Catégories</h1>
        <p class="mt-2 text-sm text-gray-700">Gérez vos postes de dépenses et sources de revenus.</p>
    </div>
    <div class="mt-4 sm:mt-0">
        <a href="{{ path('app_categorie_new') }}" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
            ➕ Nouvelle catégorie
        </a>
    </div>
</div>

<div class="flex flex-col mt-6">
    <div class="overflow-x-auto border border-gray-200 shadow sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nom</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
            {% for categorie in categories %}
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 text-sm text-gray-500">#{{ categorie.id }}</td>
                    <td class="px-6 py-4 text-sm font-medium text-gray-900 flex items-center space-x-2">
                        {# Petite pastille de couleur dynamique si tu as un champ couleur, sinon fixe #}
                        <span class="w-3 h-3 rounded-full bg-indigo-500"></span>
                        <span>{{ categorie.nom }}</span>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        {% if categorie.type.value|lower == 'revenu' %}
                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">💰 Revenu</span>
                        {% else %}
                            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">📉 Dépense</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 text-sm font-medium space-x-3">
                        <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="text-indigo-600 hover:text-indigo-900">👁️ Voir</a>
                        <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="text-amber-600 hover:text-amber-900">✏️ Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-10 text-center text-sm text-gray-500 bg-gray-50">Aucune catégorie enregistrée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}