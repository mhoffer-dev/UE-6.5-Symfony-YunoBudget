{% extends 'base.html.twig' %}

{% block title %}Modifier la catégorie — Yuno Budget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_categorie_index') }}" class="text-[var(--text-secondary)] hover:text-violet-500 transition-colors text-base font-mono font-bold">
            &larr; Retour
        </a>
    </div>

    <!-- Section Titre -->
    <div class="text-center py-6">
        <h1 class="text-2xl font-semibold tracking-tight text-[var(--text-primary)]">{{ categorie.nom }}</h1>
        <p class="text-xs text-[var(--text-secondary)] mt-1">Ajustez les détails de cette catégorie.</p>
        <div class="w-12 h-0.5 bg-gradient-to-r from-violet-500 to-pink-500 mx-auto mt-3 rounded-full"></div>
    </div>

    <!-- Formulaire dans une carte en verre -->
    <div class="glass-panel p-6 rounded-2xl text-sm">
        {{ include('categorie/_form.html.twig', {
            'button_label': 'Enregistrer les modifications',
            'categorie': categorie
        }) }}
    </div>
    
</div>
{% endblock %}