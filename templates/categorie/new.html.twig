{% extends 'base.html.twig' %}

{% block title %}Nouvelle Catégorie — YunoBudget{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 text-white">
    
    <!-- En-tête chirurgical -->
    <div class="flex items-center space-x-3 pt-2">
        <a href="{{ path('app_categorie_index') }}" class="text-zinc-400 hover:text-white transition-colors text-base font-mono">
            &larr;
        </a>
        <h1 class="text-xs font-medium tracking-tight text-zinc-400">Ajouter une catégorie</h1>
    </div>

    <!-- Section du Titre -->
    <div class="text-center py-6">
        <h1 class="text-2xl font-semibold tracking-tight text-white">Nouvelle catégorie</h1>
        <p class="text-xs text-zinc-500 mt-1">Créez un nouveau groupe pour vos dépenses ou revenus.</p>
        <div class="w-10 h-[1px] bg-zinc-800 mx-auto mt-3"></div>
    </div>

    <!-- Formulaire compact -->
    <div class="text-sm">
        {{ include('categorie/_form.html.twig', {
            'button_label': 'Créer la catégorie',
            'categorie': categorie
        }) }}
    </div>
    
</div>
{% endblock %}