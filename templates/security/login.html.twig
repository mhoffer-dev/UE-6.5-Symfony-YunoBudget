{% extends 'base.html.twig' %}

{% block title %}YunoBudget - Connexion{% endblock %}

{% block body %}
<style>
    :root {
        --bg-main: #0B0B0C; /* Fond ultra sombre de la maquette */
        --card-bg: #161618; /* Couleur secondaire Obsidian pour les cartes */
        --input-bg: #1F1F22; /* Fond des inputs */
        --border-color: #2D2D31; /* Bordure discrète */
        --text-primary: #FFFFFF; /* Blanc pur pour les titres et boutons inversés */
        --text-secondary: #8E8E93; /* Gris neutre pour les sous-titres et labels */
        --error-color: #FF453A; /* Rouge iOS pour les erreurs */
    }

    .login-wrapper, .login-wrapper * {
        box-sizing: border-box;
    }

    .login-wrapper {
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-main);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        padding: 20px;
        overflow: hidden;
    }

    .login-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        padding: 40px 35px;
        border-radius: 14px;
        width: 100%;
        max-width: 400px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .login-header h1 {
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
    }

    .login-header p {
        font-size: 13px;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.4;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        margin-bottom: 8px;
    }

    .form-group input {
        width: 100%;
        padding: 12px 14px;
        font-size: 14px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background-color: var(--input-bg);
        color: var(--text-primary);
        transition: border-color 0.2s ease;
    }

    .form-group input:focus {
        outline: none;
        border-color: #55555A;
    }

    .form-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
    }

    .form-checkbox input[type="checkbox"] {
        accent-color: var(--text-primary);
        width: 15px;
        height: 15px;
        cursor: pointer;
    }

    .form-checkbox label {
        font-size: 13px;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background-color: var(--text-primary); /* Bouton blanc éclatant comme la maquette */
        color: var(--bg-main); /* Texte sombre */
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .btn-submit:hover {
        opacity: 0.9;
    }

    .form-errors {
        background: rgba(255, 69, 58, 0.1);
        border: 1px solid rgba(255, 69, 58, 0.2);
        padding: 10px;
        border-radius: 8px;
        color: var(--error-color);
        font-size: 13px;
        margin-bottom: 18px;
        text-align: center;
    }

    .register-link {
        text-align: center;
        margin-top: 20px;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .register-link a {
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 500;
        margin-left: 4px;
    }

    .register-link a:hover {
        text-decoration: underline;
    }

    .login-footer {
        margin-top: 24px;
        font-size: 11px;
        color: #444448;
        text-align: center;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h1>Bienvenue sur Yuno</h1>
            <p>Reprenez le contrôle total de vos finances avec une clarté absolue.</p>
        </div>

        <form method="post">
            {% if error %}
                <div class="form-errors">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="form-group">
                <label for="inputEmail">Adresse Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" placeholder="nom@exemple.com" required autofocus>
            </div>

            <div class="form-group">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" autocomplete="current-password" placeholder="••••••••" required>
            </div>

            <div class="form-checkbox">
                <input type="checkbox" name="_remember_me" id="remember_me">
                <label for="remember_me">Se souvenir de moi</label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="btn-submit" type="submit">
                Se connecter
            </button>
        </form>

        <div class="register-link">
            OU <a href="{{ path('app_register') }}">Créer un compte</a>
        </div>
    </div>

    <div class="login-footer">
        &copy; 2026 YunoBudget &bull; Obsidian Precision
    </div>
</div>
{% endblock %}